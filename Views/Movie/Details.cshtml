@using CineScope.Entities
@{
    List<Movie> movies = ViewBag.SimilarMovies;
    FilterModel similarMoviesFilter = ViewBag.SimilarMoviesFilter;
}

<main class="pt-0">

    <section class="relative h-[614px] md:h-[819px] w-full overflow-hidden">
        <div class="absolute inset-0">
            <img class="w-full h-full object-cover"
                 src="@ViewBag.BackdropImageUrl"/>
            <div class="absolute inset-0 hero-gradient"></div>
        </div>
        <div class="absolute bottom-32 left-0 w-full px-margin-mobile md:px-margin-desktop pb-xl flex flex-col gap-xs">
            <span
                class="text-primary-container font-label-md text-label-md uppercase tracking-widest bg-black/40 px-md py-xs rounded-full backdrop-blur-sm w-fit">@ViewBag.Genres</span>
            <h1 class="font-display-lg-mobile md:font-display-lg text-display-lg-mobile md:text-display-lg text-on-surface max-w-4xl">
                @ViewBag.Title</h1>
            <p class="font-title-lg text-title-lg italic text-on-surface-variant">"@ViewBag.Tagline"</p>
        </div>
    </section>

    <div class="px-margin-mobile md:px-margin-desktop grid grid-cols-1 md:grid-cols-12 gap-gutter -mt-28 relative z-10">

        <aside class="md:col-span-4 flex flex-col gap-lg">
            <div
                class="rounded-xl overflow-hidden border border-surface-container-highest shadow-2xl aspect-[2/3] bg-surface-container">
                <img class="w-full h-full object-cover"
                     src="@ViewBag.PosterUrl"/>
            </div>
            <div class="flex flex-col gap-md">
                <div class="grid grid-cols-2 gap-base">
                    <button
                        class="bg-surface-container-high text-on-surface py-base rounded-lg border border-outline-variant flex items-center justify-center gap-xs hover:bg-surface-bright transition-colors">
                        <span class="material-symbols-outlined">add</span>
                        Watchlist
                    </button>
                    <button
                        class="bg-surface-container-high text-on-surface py-base rounded-lg border border-outline-variant flex items-center justify-center gap-xs hover:bg-surface-bright transition-colors">
                        <span class="material-symbols-outlined">playlist_add</span>
                        Add to List
                    </button>
                </div>
                <div
                    class="flex items-center justify-between p-md bg-surface-container rounded-lg border border-outline-variant">
                    <span class="text-label-md">Rate this</span>
                    <div class="flex gap-xs text-primary-container">
                        <span class="material-symbols-outlined text-[20px]" style="font-variation-settings: 'FILL' 1;">star</span>
                        <span class="material-symbols-outlined text-[20px]" style="font-variation-settings: 'FILL' 1;">star</span>
                        <span class="material-symbols-outlined text-[20px]" style="font-variation-settings: 'FILL' 1;">star</span>
                        <span class="material-symbols-outlined text-[20px]" style="font-variation-settings: 'FILL' 1;">star</span>
                        <span class="material-symbols-outlined text-[20px]">star</span>
                    </div>
                </div>
            </div>
        </aside>

        <section class="md:col-span-8 flex flex-col gap-xl">
            <div class="flex flex-wrap items-center gap-lg">
                <div
                    class="flex items-center gap-base px-md py-xs bg-surface-container-highest rounded-full border border-outline-variant">
                    <span class="material-symbols-outlined text-primary-container"
                          style="font-variation-settings: 'FILL' 1;">star</span>
                    <span class="font-label-md text-label-md">@ViewBag.Rating <span
                            class="text-on-surface-variant font-normal">/ 10</span></span>
                </div>
                <span class="text-on-surface-variant font-label-md">@ViewBag.ReleaseYear</span>
                <span class="text-on-surface-variant font-label-md">@ViewBag.Duration</span>
                <span
                    class="px-md py-xs border border-outline-variant rounded-full text-label-sm uppercase">@ViewBag.AgeRating</span>
            </div>
            <div class="flex flex-col gap-md">
                <h2 class="font-headline-lg text-headline-lg border-l-4 border-primary-container pl-md">Synopsis</h2>
                <p class="text-body-lg text-on-surface-variant leading-relaxed">
                    @ViewBag.Description
                </p>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-xl border-t border-surface-container-highest pt-xl">
                <div class="flex flex-col gap-xs">
                    <span class="text-primary-container font-label-sm uppercase">Director</span>
                    <span class="text-title-lg font-title-lg">@ViewBag.Director</span>
                </div>
                <div class="flex flex-col gap-xs">
                    <span class="text-primary-container font-label-sm uppercase">Cast</span>
                    <span class="text-body-md font-body-md text-on-surface-variant">@ViewBag.Actors</span>
                </div>
            </div>

            <div class="mt-xl">
                <div class="flex gap-xl border-b border-surface-container-highest mb-lg">
                    <div class="pb-md text-primary-container font-bold border-b-2 border-primary-container">Reviews
                    </div>
                </div>

                <div class="flex flex-col gap-lg">
                    <div
                        class="bg-surface-container p-lg rounded-xl border border-surface-container-highest flex flex-col gap-md">
                        <div class="flex justify-between items-start">
                            <div class="flex items-center gap-md">
                                <div class="w-12 h-12 rounded-full overflow-hidden bg-surface-container-highest">
                                    <img class="w-full h-full object-cover"
                                         src="https://lh3.googleusercontent.com/aida-public/AB6AXuDF3dV0_5643ChqUyREX-5acyyx7T9-6knJVLhtng5Ct4zK75k51Z04Izj6bPdWP7n6H5irUwWrAlUBgQAsz9Jes0lSZKwWZhVHYBh_5GvrfqgaIyl7s1qvU6uqGVLvpk5-Ep5KBp51cVHyO9wcZrcl5glciUx8C3RdVr4G4I5vqkkbqiqLb493x50UpRSQfOZkdpPu6Uu3k1mrK9hURYmAhZyzf6Ey9REzTeaaGiuM5eRe8-B3FSe5iCoGxmL3I2ecegCzoSeyqPU"/>
                                </div>
                                <div>
                                    <h4 class="font-label-md text-label-md">Alex Rivera</h4>
                                    <span class="text-label-sm text-on-surface-variant">October 14, 2023</span>
                                </div>
                            </div>
                            <div
                                class="px-md py-xs bg-primary-container/10 border border-primary-container/20 rounded-lg text-primary-container font-bold text-label-md">
                                9/10
                            </div>
                        </div>
                        <p class="text-body-md text-on-surface-variant">
                            Inception is a rare masterpiece that combines high-octane action with a deeply intellectual
                            narrative. Nolan's direction is impeccable, guiding the audience through layers of dreams
                            without ever losing the emotional core. The visual effects still hold up remarkably well.
                            Truly a cinematic landmark.
                        </p>
                    </div>
                    <div
                        class="bg-surface-container p-lg rounded-xl border border-surface-container-highest flex flex-col gap-md">
                        <div class="flex justify-between items-start">
                            <div class="flex items-center gap-md">
                                <div class="w-12 h-12 rounded-full overflow-hidden bg-surface-container-highest">
                                    <img alt="User Avatar" class="w-full h-full object-cover"
                                         src="https://lh3.googleusercontent.com/aida-public/AB6AXuD9S33vD_kE_26p-E6B9E_E5H7m2jR_3qK4S_N5n-V-wL_8y-zX-F-Q_J8-X-L-J-X-L-J-X-L-J"/>
                                </div>
                                <div>
                                    <h4 class="font-label-md text-label-md">Sarah Jenkins</h4>
                                    <span class="text-label-sm text-on-surface-variant">October 12, 2023</span>
                                </div>
                            </div>
                            <div
                                class="px-md py-xs bg-primary-container/10 border border-primary-container/20 rounded-lg text-primary-container font-bold text-label-md">
                                10/10
                            </div>
                        </div>
                        <p class="text-body-md text-on-surface-variant">An absolute tour de force. The layering of
                            reality and the practical effects are mind-blowing. Hans Zimmer's score is the perfect
                            companion to this journey.</p>
                    </div>
                    <div
                        class="bg-surface-container p-lg rounded-xl border border-surface-container-highest flex flex-col gap-md">
                        <div class="flex justify-between items-start">
                            <div class="flex items-center gap-md">
                                <div class="w-12 h-12 rounded-full overflow-hidden bg-surface-container-highest">
                                    <img alt="User Avatar" class="w-full h-full object-cover"
                                         src="https://lh3.googleusercontent.com/aida-public/AB6AXuD_X_P_X_P_X_P_X_P_X_P_X_P_X_P_X_P_X_P_X_P_X_P_X_P_X_P_X_P_X_P_X_P_X"/>
                                </div>
                                <div>
                                    <h4 class="font-label-md text-label-md">Michael Chen</h4>
                                    <span class="text-label-sm text-on-surface-variant">October 10, 2023</span>
                                </div>
                            </div>
                            <div
                                class="px-md py-xs bg-primary-container/10 border border-primary-container/20 rounded-lg text-primary-container font-bold text-label-md">
                                8/10
                            </div>
                        </div>
                        <p class="text-body-md text-on-surface-variant">Complex, visually stunning, and ambitious. It
                            requires multiple viewings to fully grasp everything, but that's part of the fun. A bit long
                            in parts, but worth it.</p>
                    </div>
                </div>
            </div>

            <div class="mt-xl">
                <div class="flex items-center justify-between mb-lg">
                    <h3 class="font-headline-md text-headline-md">Similar Movies</h3>
                    <a class="text-primary-container font-label-md hover:underline" href="@($"/movies{similarMoviesFilter}")">See all</a>
                </div>
                <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-gutter overflow-x-auto pb-md">
                    @foreach (var movie in movies)
                    {
                        <a href="/movies/@movie.Id"
                           class="movie-card-hover transition-all duration-300 border border-transparent rounded-lg overflow-hidden group cursor-pointer bg-surface-container">
                            <div class="aspect-[2/3] relative">
                                <img
                                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                                    src="@movie.PosterUrl"/>
                                <div
                                    class="absolute top-2 right-2 px-xs py-xs bg-black/60 backdrop-blur rounded flex items-center gap-xs">
                                    <span class="material-symbols-outlined text-primary-container text-[14px]"
                                          style="font-variation-settings: 'FILL' 1;">star</span>
                                    <span class="text-[12px] font-bold">@movie.Rating.ToString("N1")</span>
                                </div>
                            </div>
                            <div class="p-base">
                                <h5 class="text-label-md font-bold truncate">@movie.Title</h5>
                                <p class="text-label-sm text-on-surface-variant">@movie.ReleaseYear • @movie.Genres.First().Name</p>
                            </div>
                        </a>
                    }
                </div>
            </div>
        </section>
    </div>
</main>

@section Scripts {
    <script src="~/js/movie-details.js"></script>
}
