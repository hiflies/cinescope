@{
    ViewData["Title"] = "CineScope - Sign In";
    Layout = "_LoginLayout";
}

<main class="flex-grow flex items-center justify-center relative pt-20 overflow-hidden">
    <div class="absolute inset-0 z-0">
        <img alt="Cinematic background" class="w-full h-full object-cover opacity-40"
             src="https://lh3.googleusercontent.com/aida-public/AB6AXuAuxavAYi9Ihnymo3qLfItKgjjuxxXKMTOIucPz7NZSv-gv7rhrl04T06WpMuqbOB_4bIvbMxss2CMdnVkuCNhC9iH7y6vlZT9GCz_DndyEP2SuTrWZatCeLnCtTUWrjeR-BTCxb6b-aFasplllsQ7A5aSvlPYwymRc0BWGRB6zP34n-M1SDeMBdf4ACX1V_afS1AOSP4HCw-M4PSsrM1Lkkwe46JpP37xwbInwbxMySiPLxTV1IeKuf9TppBF4FVqbBQvO3HNiMPI"/>
        <div class="absolute inset-0 bg-gradient-to-t from-background via-transparent to-background opacity-90"></div>
    </div>
    <div class="relative z-10 w-full max-w-md px-margin-mobile">
        <div class="glass-card rounded-xl p-xl shadow-2xl transition-auth">
            <div class="flex flex-col items-center mb-xl">
                <h1 class="font-headline-lg text-headline-lg mb-xs text-on-surface">Welcome Back</h1>
                <p class="text-on-surface-variant font-body-md text-center">Enter your details to
                    access your cinematic universe.</p>
            </div>
            <form method="post" class="space-y-lg">
                <div class="space-y-xs">
                    <label class="font-label-md text-on-surface-variant block" for="identifier">Email or
                        Username</label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-md top-1/2 -translate-y-1/2 text-outline">alternate_email</span>
                        <input
                            id="identifier"
                            class="w-full bg-surface-container border border-surface-variant rounded-lg py-sm pl-11 pr-md text-on-surface input-focus-gold transition-colors"
                            name="identifier" placeholder="name@@example.com" required="" type="text"/>
                    </div>
                </div>
                <div class="space-y-xs">
                    <div class="flex justify-between items-center">
                        <label class="font-label-md text-on-surface-variant" for="password">Password</label>
                    </div>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-md top-1/2 -translate-y-1/2 text-outline">lock</span>
                        <input
                            id="password"
                            class="w-full bg-surface-container border border-surface-variant rounded-lg py-sm pl-11 pr-md text-on-surface input-focus-gold transition-colors"
                            name="password" placeholder="••••••••" required="" type="password"/>
                        <button
                            tabindex="-1"
                            class="password-toggle absolute right-md top-1/2 -translate-y-1/2 text-outline hover:text-on-surface"
                            type="button">
                            <span class="material-symbols-outlined" style="font-size: 20px;">visibility</span>
                        </button>
                    </div>
                </div>

                <div class="flex items-center gap-sm">
                    <input
                        class="w-4 h-4 rounded border-outline-variant bg-surface-container text-primary-container focus:ring-primary-container focus:ring-offset-background"
                        type="checkbox"/>
                    <label class="font-label-md text-on-surface-variant" for="remember">Keep me logged in</label>
                </div>

                <button
                    class="w-full bg-secondary-container text-on-secondary-container font-label-md py-md rounded-lg hover:brightness-110 active:scale-[0.98] transition-all flex justify-center items-center gap-sm"
                    type="submit">
                    <span>Sign In</span>
                    <span class="material-symbols-outlined" style="font-size: 18px;">arrow_forward</span>
                </button>
            </form>

            <div class="mt-xl text-center">
                <p class="text-on-surface-variant font-body-md">
                    Don't have an account?
                    <a href="/create-account" class="text-primary font-bold hover:underline">Create Account</a>
                </p>
            </div>
        </div>
    </div>
</main>

