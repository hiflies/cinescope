@using CineScope.Entities
@{
    ViewData["Title"] = "CineScope - Admin - Dashboard";
    Layout = "_AdminLayout";
    List<Movie> recentlyAddedMovies = ViewBag.RecentlyAddedMovies;
}

<section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-gutter">
    <div class="glass-card p-lg rounded-xl transition-transform duration-300 hover:scale-[1.02]">
        <div class="flex justify-between items-start mb-md">
            <span class="p-sm bg-surface-variant/40 text-on-surface rounded-lg h-[48px]">
                <span class="material-symbols-outlined" data-icon="movie">movie</span>
            </span>
        </div>
        <p class="font-label-md text-label-md text-on-surface-variant mb-xs">Total Movies</p>
        <h3 class="font-headline-md text-headline-md font-bold">@ViewBag.TotalMovies</h3>
    </div>
    <div class="glass-card p-lg rounded-xl transition-transform duration-300 hover:scale-[1.02]">
        <div class="flex justify-between items-start mb-md">
            <span class="p-sm bg-tertiary-container/20 text-tertiary-container rounded-lg h-[48px]">
                <span class="material-symbols-outlined" data-icon="diversity_3">diversity_3</span>
            </span>
        </div>
        <p class="font-label-md text-label-md text-on-surface-variant mb-xs">Total Users</p>
        <h3 class="font-headline-md text-headline-md font-bold">@ViewBag.TotalUsers</h3>
    </div>
    <div class="glass-card p-lg rounded-xl transition-transform duration-300 hover:scale-[1.02]">
        <div class="flex justify-between items-start mb-md">
            <span class="p-sm bg-secondary-container/20 text-secondary-container rounded-lg h-[48px]">
                <span class="material-symbols-outlined" data-icon="comment">comment</span>
            </span>
        </div>
        <p class="font-label-md text-label-md text-on-surface-variant mb-xs">Total Reviews</p>
        <h3 class="font-headline-md text-headline-md font-bold">@ViewBag.TotalReviews</h3>
    </div>
    <div class="glass-card p-lg rounded-xl transition-transform duration-300 hover:scale-[1.02]">
        <div class="flex justify-between items-start mb-md">
            <span class="p-sm bg-primary-container/20 text-primary-container rounded-lg h-[48px]">
                 <span class="material-symbols-outlined" data-icon="star">star</span>
            </span>
            <span class="text-primary-container font-label-md">@ViewBag.TopRatedMovie.Rating.ToString("N1")</span>
        </div>
        <p class="font-label-md text-label-md text-on-surface-variant mb-xs">Top Rated Movie</p>
        <h3 class="font-headline-md text-headline-md font-bold">@ViewBag.TopRatedMovie.Title</h3>
    </div>
</section>

<section class="grid grid-cols-1 xl:grid-cols-3 gap-gutter items-start">
    <div class="xl:col-span-3 glass-card rounded-xl overflow-hidden">
        <div class="p-lg border-b border-surface-variant flex justify-between items-center">
            <h2 class="font-title-lg text-title-lg">Recent Movies Added</h2>
            <a href="/admin/movies" class="text-primary font-label-md hover:underline">View All</a>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead class="bg-surface-container-low text-on-surface-variant font-label-sm text-label-sm">
                <tr>
                    <th class="px-lg py-md">Movie Title</th>
                    <th class="px-lg py-md">Genre</th>
                    <th class="px-lg py-md">Release Year</th>
                    <th class="px-lg py-md">Actions</th>
                </tr>
                </thead>
                <tbody class="divide-y divide-surface-variant">
                @foreach (var movie in recentlyAddedMovies)
                {
                    <tr class="hover:bg-surface-container-high transition-colors">
                        <td class="px-lg py-lg flex items-center gap-md">
                            <div class="w-10 h-14 rounded bg-surface-variant flex-shrink-0">
                                <img class="w-full h-full object-cover rounded"
                                     src="@movie.PosterUrl"/>
                            </div>
                            <span class="font-body-md text-body-md">@movie.Title</span>
                        </td>
                        <td class="px-lg py-lg font-body-md text-body-md">@string.Join(", ", movie.Genres.Select(g => g.Name))</td>
                        <td class="px-lg py-lg font-body-md text-body-md text-on-surface-variant">@movie.ReleaseYear</td>
                        <td class="px-lg py-lg">
                            <a href="/admin/movies/@movie.Id"
                               class="text-on-surface-variant hover:text-primary transition-colors">
                                <span class="material-symbols-outlined" data-icon="edit">
                                    edit
                                </span>
                            </a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</section>

@section Scripts {
    <script src="~/js/admin-dashboard.js"></script>
}

@section NavBar{
    <div class="relative w-full max-w-md">
        <form method="get" action="/admin/tmdb">
            <span
                class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant">search</span>
            <input
                name="search"
                type="text"
                onkeydown="e=> e.key === 'Enter' && e.target.parent.submit()"
                class="w-full bg-surface-container-low border border-outline-variant rounded-full py-2 pl-10 pr-4 text-on-surface placeholder:text-on-surface-variant focus:outline-none focus:border-primary-container transition-all"
                placeholder="Search on tmdb...">
        </form>
    </div>
}
