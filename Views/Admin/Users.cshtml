                <span class="material-symbols-outlined text-3xl">workspace_premium</span>
            </div>
            <div>
                <p class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider">Total
                    Premium Users</p>
                <h3 class="font-headline-md text-headline-md text-on-surface">12.4k</h3>
            </div>
        </div>
        <div class="glass-card p-lg rounded-2xl flex items-center gap-lg">
            <div class="w-14 h-14 rounded-xl bg-error-container/20 flex items-center justify-center text-secondary">
                <span class="material-symbols-outlined text-3xl">report</span>
            </div>
            <div>
                <p class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider">Flagged
                    Accounts</p>
                <h3 class="font-headline-md text-headline-md text-on-surface">142</h3>
            </div>
        </div>
        <div class="glass-card p-lg rounded-2xl flex items-center gap-lg">
            <div
                class="w-14 h-14 rounded-xl bg-tertiary-container/10 flex items-center justify-center text-tertiary">
                <span class="material-symbols-outlined text-3xl">insights</span>
            </div>
            <div>
                <p class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider">Avg.
                    Engagement Score</p>
                <h3 class="font-headline-md text-headline-md text-on-surface">8.4/10</h3>
            </div>
        </div>
    </div>
</div>
