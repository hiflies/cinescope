                <a class="flex items-center gap-sm px-md py-sm text-on-surface-variant hover:bg-surface-variant/50 hover:text-on-surface rounded-lg transition-all font-label-md" href="#">
                    <span class="material-symbols-outlined">history</span>
                    Watch History
