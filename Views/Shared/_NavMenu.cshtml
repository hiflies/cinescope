@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
}
<nav
    class="fixed top-0 w-full z-50 bg-surface/0 transition-all duration-500 border-b border-transparent flex justify-between items-center px-margin-mobile md:px-margin-desktop py-4"
    id="top-nav">
    <div class="flex items-center gap-xl">
        <a href="/" class="font-display-lg-mobile md:text-headline-lg font-bold text-primary-container tracking-tight">CineScope</a>
        <div class="hidden md:flex gap-lg items-center">
            <a
                class="@(currentController == "Movie" ? "text-primary-container font-bold border-b-2 border-primary-container pb-1" : "text-on-surface-variant hover:text-on-surface transition-colors") font-body-md text-body-md"
                href="/movies">Movies</a>
        </div>
    </div>
    <div class="flex items-center gap-base">
        <form id="search-form" method="get" action="/movies">
            <div class="hidden sm:flex relative items-center">
                <span class="material-symbols-outlined absolute left-3 text-on-surface-variant">search</span>
                <input
                    name="search"
                    value="@Context.Request.Query["search"]"
                    onkeydown="e=> e.key === 'Enter' && e.target.parent.parent.submit()"
                    class="bg-surface-container-high border-none rounded-full pl-10 pr-4 py-2 text-label-md focus:ring-1 focus:ring-primary-container w-64"
                    placeholder="Search movies..." type="text"/>
            </div>
        </form>
        <button
            id="theme-toggle"
            type="button"
            class="h-[40px] w-[40px] flex items-center justify-center rounded-full hover:bg-surface-variant text-on-surface transition-colors"
            title="Toggle theme">
            <span class="material-symbols-outlined" id="theme-icon">dark_mode</span>
        </button>

        @if (User.Identity?.IsAuthenticated == true)
        {
            <div
                id="nav-login-bar"
                class="flex items-center gap-xs bg-surface/80 backdrop-blur-md border-surface-container-highest rounded-full transition-all">
                <partial name="_Avatar"/>

                @if (User.IsInRole("admin"))
                {
                    <a href="/admin"
                       title="Admin"
                       class="h-[40px] p-base text-center vertical-middle rounded-full hover:bg-surface-variant text-on-surface transition-colors">
                        <span class="material-symbols-outlined" data-icon="dashboard">dashboard</span>
                    </a>
                }

                <form method="post" action="/logout" class="inline">
                    @Html.AntiForgeryToken()
                    <button
                        class="h-[40px] p-base text-center vertical-middle rounded-full hover:bg-surface-variant text-on-surface transition-colors">
                        <span class="material-symbols-outlined" data-icon="logout">logout</span>
                    </button>
                </form>
            </div>
        }
        else
        {
            <a href="/login"
               class="bg-secondary-container text-on-secondary-container px-xl py-base rounded-full font-label-md hover:opacity-90 transition-all">
                Login
            </a>
        }
    </div>
</nav>
