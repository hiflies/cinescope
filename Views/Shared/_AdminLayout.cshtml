@{
    Layout = "_BaseLayout";
}

<body class="admin flex overflow-hidden h-screen">
    <partial name="_AdminSideBar" />
    <main class="flex-1 flex flex-col min-w-0 overflow-hidden bg-background">
        <header class="flex justify-between items-center px-margin-desktop w-full h-16 bg-surface border-b border-surface-variant z-20">
            <div class="flex items-center gap-xl">
                <h1 class="font-headline-lg text-headline-lg font-bold text-primary-fixed-dim shrink-0">CineScope Admin</h1>
                @await RenderSectionAsync("NavBar", required: false)
            </div>
            <div class="flex items-center gap-lg">
                <partial name="_Avatar"/>

                <a href="/"
                   title="Home"
                   class="h-[40px] p-base text-center vertical-middle rounded-full hover:bg-surface-variant text-on-surface transition-colors">
                    <span class="material-symbols-outlined" data-icon="home">home</span>
                </a>

                <form method="post" action="/logout" class="inline">
                    @Html.AntiForgeryToken()
                    <button
                        class="h-[40px] p-base text-center vertical-middle rounded-full hover:bg-surface-variant text-on-surface transition-colors">
                        <span class="material-symbols-outlined" data-icon="logout">logout</span>
                    </button>
                </form>
            </div>
        </header>
        <div class="flex-1 overflow-y-auto custom-scrollbar p-margin-desktop space-y-xl">
            @RenderBody()
        </div>
        <div class="absolute bottom-0 left-0 w-full h-32 bg-gradient-to-t from-background to-transparent pointer-events-none"></div>
    </main>
    @await RenderSectionAsync("Scripts", required: false)
</body>
