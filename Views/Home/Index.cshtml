@{
    ViewData["Title"] = "Home";
    List<Movie> featuredMovies = ViewBag.FeaturedMovies;
    List<Movie> recentlyAddedMovies = ViewBag.RecentlyAddedMovies;
    List<Movie> topRatedMovies = ViewBag.TopRatedMovies;
    List<Genre> genres = ViewBag.Genres;

    var featuredMovieIndex = 0;
}

<header class="relative h-[85vh] w-full overflow-hidden" id="hero">
    @foreach (var movie in featuredMovies)
    {
        <div class="hero-slide@(featuredMovieIndex == 0 ? " active" : "")" data-index="@featuredMovieIndex">
            <div class="absolute inset-0 bg-cover bg-center"
                 style="background-image: url('@movie.BackdropImageUrl')"></div>
            <div class="hero-gradient absolute inset-0 z-20"></div>
            <div
                class="relative z-30 flex flex-col justify-center h-full px-margin-mobile md:px-margin-desktop max-w-4xl">
                <div class="flex items-center gap-sm mb-base">
                    <span
                        class="bg-primary-container text-on-primary font-bold px-2 py-1 rounded text-label-sm">@movie.Rating.ToString("N1")</span>
                    <span
                        class="text-on-surface-variant font-label-md">@movie.ReleaseYear • @string.Join(", ", @movie.Genres.Select(g => g.Name))</span>
                </div>
                <h1 class="font-display-lg-mobile md:text-display-lg text-on-surface mb-md">@movie.Title</h1>
                <p class="font-body-lg text-on-surface-variant mb-xl max-w-xl">@movie.Tagline</p>
                <div class="flex gap-base">
                    <a href="/movies/@movie.Id"
                       class="border-2 border-on-surface text-on-surface px-xl py-sm rounded-lg font-label-md hover:bg-on-surface hover:text-background transition-all">See
                        details</a>
                    <button
                        class="bg-secondary-container text-white px-xl py-sm rounded-lg font-label-md hover:brightness-110 transition-all flex items-center gap-xs">
                        <span class="material-symbols-outlined">add</span> Add to watchlist
                    </button>
                </div>
            </div>
        </div>

        featuredMovieIndex++;
    }
</header>

<main class="relative z-30 pb-xl">

    <section
        class="relative z-40 pt-lg pb-[10px] px-margin-mobile md:px-margin-desktop border-b border-surface-container-highest bg-background/50 backdrop-blur-sm sticky top-[15px]">
        <div class="flex items-center justify-between mb-sm">
            <h2 class="font-headline-md text-title-lg text-on-surface">Browse by Genre</h2>
        </div>
        <div class="movie-row-scroll flex gap-sm overflow-x-auto pb-2">
            @foreach (var genre in genres)
            {
                <a class="flex-none px-lg py-1.5 bg-surface-container-low border border-surface-container-highest rounded-full text-label-md text-on-surface hover:border-primary-container hover:text-primary-container transition-all"
                   href="/movies?genreId=@genre.Id">@genre.Name</a>
            }
        </div>
    </section>

    <section class="mt-xl mb-xl px-margin-mobile md:px-margin-desktop">
        <div class="flex justify-between items-center mb-base">
            <h2 class="font-headline-md text-headline-md">Recently Added</h2>
            <a class="text-primary-container font-label-md hover:underline" href="/movies?sortBy=newest">See all</a>
        </div>
        <div class="movie-row-scroll flex gap-gutter overflow-x-auto pb-4">
            @foreach (var movie in recentlyAddedMovies)
            {
                <a href="/movies/@movie.Id" class="flex-none w-[160px] md:w-[220px] group cursor-pointer">
                    <div
                        class="relative aspect-[2/3] rounded-lg overflow-hidden border border-surface-container-highest transition-transform duration-300 group-hover:scale-105 group-hover:shadow-2xl">
                        <img class="w-full h-full object-cover"
                             src="@movie.PosterUrl"/>
                        <div
                            class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition-opacity flex flex-col justify-end p-base">
                            <div class="absolute top-2 right-2 flex flex-col gap-xs">
                            <span
                                class="bg-primary-container text-on-primary-container px-2 py-0.5 rounded text-[10px] font-bold">@movie.Rating.ToString("N1")</span>
                            </div>
                            <div class="flex justify-between items-center">
                            <span class="material-symbols-outlined text-white hover:text-error transition-colors"
                                  onclick="heartPop(this)">favorite</span>
                                <span
                                    class="material-symbols-outlined text-white hover:text-primary-container">add_circle</span>
                                <span
                                    class="material-symbols-outlined text-white hover:text-primary-container">star</span>
                            </div>
                        </div>
                    </div>
                    <p class="mt-base font-title-lg text-on-surface truncate group-hover:text-primary-container transition-colors">
                        @movie.Title</p>
                    <p class="text-label-sm text-on-surface-variant">@movie.ReleaseYear</p>
                </a>
            }
        </div>
    </section>

    <section class="mb-xl px-margin-mobile md:px-margin-desktop">
        <div class="flex justify-between items-center mb-base">
            <h2 class="font-headline-md text-headline-md">Top Rated</h2>
            <a class="text-primary-container font-label-md hover:underline" href="/movies?sortBy=rating">See all</a>
        </div>
        <div class="movie-row-scroll flex gap-gutter overflow-x-auto pb-4">
            @foreach (var movie in topRatedMovies)
            {
            <a href="/movies/@movie.Id" class="flex-none w-[160px] md:w-[220px] group cursor-pointer">
                <div
                    class="relative aspect-[2/3] rounded-lg overflow-hidden border border-surface-container-highest transition-transform duration-300 group-hover:scale-105 group-hover:shadow-2xl">
                    <img class="w-full h-full object-cover"
                         src="@movie.PosterUrl"/>
                    <div
                        class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition-opacity flex flex-col justify-end p-base">
                        <div class="absolute top-2 right-2 flex flex-col gap-xs">
                            <span
                                class="bg-primary-container text-on-primary-container px-2 py-0.5 rounded text-[10px] font-bold">@movie.Rating.ToString("N1")</span>
                        </div>
                        <div class="flex justify-between items-center">
                            <span class="material-symbols-outlined text-white hover:text-error transition-colors"
                                  onclick="heartPop(this)">favorite</span>
                            <span
                                class="material-symbols-outlined text-white hover:text-primary-container">add_circle</span>
                            <span
                                class="material-symbols-outlined text-white hover:text-primary-container">star</span>
                        </div>
                    </div>
                </div>
                <p class="mt-base font-title-lg text-on-surface truncate group-hover:text-primary-container transition-colors">
                    @movie.Title</p>
                <p class="text-label-sm text-on-surface-variant">@movie.ReleaseYear</p>
            </a>
            }
        </div>
    </section>

</main>

@section Scripts {
    <script src="~/js/home.js"></script>
}
