            class="w-12 h-12 rounded-full bg-primary-container/10 flex items-center justify-center text-primary-container">
            <span class="material-symbols-outlined text-3xl">trending_up</span>
        </div>
        <div>
            <p class="text-label-sm text-on-surface-variant uppercase tracking-wider">Storage Used</p>
            <h4 class="text-headline-md font-bold text-on-surface">14.2 TB</h4>
        </div>
    </div>
    <div class="glass-card p-lg rounded-xl flex items-center gap-lg">
        <div class="w-12 h-12 rounded-full bg-tertiary-container/10 flex items-center justify-center text-tertiary">
            <span class="material-symbols-outlined text-3xl">visibility</span>
        </div>
        <div>
            <p class="text-label-sm text-on-surface-variant uppercase tracking-wider">Global Views</p>
            <h4 class="text-headline-md font-bold text-on-surface">2.8M</h4>
        </div>
    </div>
    <div class="glass-card p-lg rounded-xl flex items-center gap-lg">
