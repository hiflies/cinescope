@page "/admin/movies"
@layout AdminLayout

<PageTitle>CineScope - Admin - Movies</PageTitle>

<div class="movie-management flex justify-between items-end">
    <div>
        <h2 class="font-headline-lg text-headline-lg text-on-surface">Movie Library</h2>
        <p class="text-body-md text-on-surface-variant">Manage your catalog of 1,248 cinematic masterpieces.</p>
    </div>
    <button
        class="flex items-center gap-md bg-secondary-container text-on-secondary-container font-bold px-lg py-sm rounded-lg hover:scale-105 active:scale-95 transition-all duration-300">
        <span class="material-symbols-outlined">add</span>
        New Entry
    </button>
</div>
<div class="movie-management glass-card rounded-xl p-md flex flex-wrap items-center justify-between gap-md">
    <div class="flex flex-wrap items-center gap-md">
        <div class="flex items-center border-r border-outline-variant pr-md gap-sm">
            <input
                class="rounded border-outline-variant bg-surface-container-low text-primary-container focus:ring-primary-container cursor-pointer"
                id="selectAll" type="checkbox">
            <span class="text-label-md text-on-surface-variant">Select All</span>
        </div>
        <div class="flex items-center gap-sm">
            <select
                class="bg-surface-container-low border border-outline-variant rounded-lg px-md py-sm text-label-md text-on-surface focus:border-primary-container outline-none">
                <option>All Genres</option>
                <option>Sci-Fi</option>
                <option>Drama</option>
                <option>Noir</option>
                <option>Action</option>
            </select>
            <select
                class="bg-surface-container-low border border-outline-variant rounded-lg px-md py-sm text-label-md text-on-surface focus:border-primary-container outline-none">
                <option>Status: Any</option>
                <option>Live</option>
                <option>Pending</option>
                <option>Archived</option>
            </select>
            <select
                class="bg-surface-container-low border border-outline-variant rounded-lg px-md py-sm text-label-md text-on-surface focus:border-primary-container outline-none">
                <option>Year: 2024</option>
                <option>Year: 2023</option>
                <option>Year: 2022</option>
                <option>Classic</option>
            </select>
        </div>
    </div>
    <div class="flex items-center gap-md">
        <button
            class="flex items-center gap-xs text-on-surface-variant hover:text-on-surface bg-surface-container-low border border-outline-variant px-md py-sm rounded-lg transition-colors">
            <span class="material-symbols-outlined text-sm">edit</span>
            Bulk Edit
        </button>
        <button
            class="flex items-center gap-xs text-secondary-container hover:bg-secondary-container hover:text-on-secondary-container border border-secondary-container px-md py-sm rounded-lg transition-all">
            <span class="material-symbols-outlined text-sm">delete</span>
            Delete Selected
        </button>
    </div>
</div>
