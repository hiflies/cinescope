@page "/admin/movies/1"
@layout AdminLayout

<PageTitle>CineScope - Admin - Edit Movie</PageTitle>

<div class="flex justify-between items-end mb-xl">
    <div>
        <nav class="flex items-center gap-base text-label-sm text-on-surface-variant mb-base">
            <span>Library</span>
            <span class="material-symbols-outlined text-[14px]">chevron_right</span>
            <span class="text-primary-container">Edit Movie</span>
        </nav>
        <h2 class="font-headline-lg text-headline-lg text-on-surface">Edit: Interstellar (2014)</h2>
    </div>
    <div class="flex items-center gap-md">
        <button
            class="px-xl py-md rounded-lg border border-outline-variant text-on-surface font-label-md hover:bg-surface-container-low transition-colors">
            Discard Changes
        </button>
        <button
            class="px-xl py-md rounded-lg bg-secondary-container text-on-secondary-container font-label-md hover:brightness-110 active:scale-95 transition-all flex items-center gap-base">
            <span class="material-symbols-outlined">save</span>
            Save Changes
        </button>
    </div>
</div>

<div class="grid grid-cols-12 gap-gutter">
    
    <div class="col-span-12 lg:col-span-8 space-y-gutter">
        
        <section class="glass-card p-xl rounded-xl">
            <h3 class="font-title-lg text-title-lg mb-lg flex items-center gap-base">
                <span class="material-symbols-outlined text-primary-container">info</span>
                Primary Movie Details
            </h3>
            <div class="grid grid-cols-2 gap-md">
                <div class="col-span-2 md:col-span-1 flex flex-col gap-xs">
                    <label class="text-label-md text-on-surface-variant px-xs">Movie Title</label>
                    <input
                        class="bg-surface-container-low border border-outline-variant rounded-lg p-md text-body-md text-on-surface"
                        type="text" value="Interstellar">
                </div>
                <div class="col-span-2 md:col-span-1 flex flex-col gap-xs">
                    <label class="text-label-md text-on-surface-variant px-xs">Tagline</label>
                    <input
                        class="bg-surface-container-low border border-outline-variant rounded-lg p-md text-body-md text-on-surface italic"
                        type="text" value="Mankind was born on Earth. It was never meant to die here.">
                </div>
                <div class="col-span-2 md:col-span-1 flex flex-col gap-xs">
                    <label class="text-label-md text-on-surface-variant px-xs">Release Date</label>
                    <input
                        class="bg-surface-container-low border border-outline-variant rounded-lg p-md text-body-md text-on-surface"
                        type="date" value="2014-11-07">
                </div>
                <div class="col-span-2 md:col-span-1 flex flex-col gap-xs">
                    <label class="text-label-md text-on-surface-variant px-xs">Duration (Minutes)</label>
                    <input
                        class="bg-surface-container-low border border-outline-variant rounded-lg p-md text-body-md text-on-surface"
                        type="number" value="169">
                </div>
                <div class="col-span-2 md:col-span-1 flex flex-col gap-xs">
                    <label class="text-label-md text-on-surface-variant px-xs">Genre (Select Multiple)</label>
                    <div
                        class="flex flex-wrap gap-xs p-base bg-surface-container-low border border-outline-variant rounded-lg min-h-[56px]">
                            <span
                                class="bg-primary-container text-on-primary-container px-sm py-xs rounded-full text-label-sm flex items-center gap-xs">Sci-Fi <button
                                    class="material-symbols-outlined text-[14px]">close</button></span>
                        <span
                            class="bg-primary-container text-on-primary-container px-sm py-xs rounded-full text-label-sm flex items-center gap-xs">Drama <button
                                class="material-symbols-outlined text-[14px]">close</button></span>
                        <span
                            class="bg-primary-container text-on-primary-container px-sm py-xs rounded-full text-label-sm flex items-center gap-xs">Adventure <button
                                class="material-symbols-outlined text-[14px]">close</button></span>
                        <button
                            class="text-on-surface-variant hover:text-primary-container px-sm py-xs border border-dashed border-outline-variant rounded-full text-label-sm">
                            + Add Genre
                        </button>
                    </div>
                </div>
                <div class="col-span-2 md:col-span-1 flex flex-col gap-xs">
                    <label class="text-label-md text-on-surface-variant px-xs">Age Rating</label>
                    <select
                        class="bg-surface-container-low border border-outline-variant rounded-lg p-md text-body-md text-on-surface">
                        <option value="G">G - General Audience</option>
                        <option value="PG">PG - Parental Guidance Suggested</option>
                        <option selected="" value="PG-13">PG-13 - Parents Strongly Cautioned</option>
                        <option value="R">R - Restricted</option>
                        <option value="NC-17">NC-17 - Adults Only</option>
                    </select>
                </div>
            </div>
        </section>
        
        <section class="glass-card p-xl rounded-xl">
            <h3 class="font-title-lg text-title-lg mb-lg flex items-center gap-base">
                <span class="material-symbols-outlined text-primary-container">description</span>
                Movie Synopsis
            </h3>
            <textarea
                class="w-full bg-surface-container-low border border-outline-variant rounded-lg p-md text-body-md text-on-surface leading-relaxed resize-none"
                rows="8">When Earth becomes uninhabitable in the future, a farmer and ex-NASA pilot, Joseph Cooper, is tasked to pilot a spacecraft, along with a team of researchers, to find a new planet for humans. They travel through a wormhole in search of a new home for humanity, encountering strange worlds and grappling with the relativity of time while Cooper desperately tries to ensure he can return to his daughter.</textarea>
            <p class="text-label-sm text-on-surface-variant mt-sm text-right">Words: 84 | Characters: 486</p>
        </section>
        
        <section class="glass-card p-xl rounded-xl">
            <h3 class="font-title-lg text-title-lg mb-lg flex items-center gap-base">
                <span class="material-symbols-outlined text-primary-container">image</span>
                Media Management
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-lg">
                <div class="md:col-span-1">
                    <p class="text-label-md text-on-surface-variant mb-md px-xs">Movie Poster (2:3)</p>
                    <div
                        class="relative group aspect-[2/3] rounded-lg overflow-hidden border-2 border-dashed border-outline-variant hover:border-primary-container transition-colors cursor-pointer">
                        <img class="w-full h-full object-cover"
                             data-alt="A cinematic movie poster for a space exploration epic titled Interstellar. The poster features a lone astronaut in a high-tech white space suit standing on a frozen alien planet with towering ice structures. The lighting is cold and atmospheric with deep blue and crisp white tones, reflecting a premium cinematic look. The title is written in bold, clean typography at the bottom with a dark charcoal border."
                             src="https://lh3.googleusercontent.com/aida-public/AB6AXuBk-i5Tji9XF7ic_frY6BVikyt0NNEiTxhrRdKs0HNdu10zCQPH8mSXlN6LZqgcP6Jt7ff7LjIQ6rVw1FANEgnwliGkuCh3yQzw9qLwM2ofMu2Zunqa4jBXZi5e7_MvYjyxyjHMW3UMuSehbhnHpMyqiax5zp50JzJY28eS54pE-MRmDlFbvPIcde2iKH2y1bYvEm6oI2A865s1O2RZ4bCO54KuJ60mBz9cIrlRqVeyOeRSBZmxEYdxMzAeRYjKXXcjy11SQcKIC20">
                        <div
                            class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition-opacity flex flex-col items-center justify-center gap-md">
                                <span
                                    class="material-symbols-outlined text-primary-container text-4xl">cloud_upload</span>
                            <p class="font-label-md text-white">Change Poster</p>
                        </div>
                    </div>
                </div>
                <div class="md:col-span-2">
                    <p class="text-label-md text-on-surface-variant mb-md px-xs">Hero Backdrop (16:9)</p>
                    <div
                        class="relative group aspect-video rounded-lg overflow-hidden border-2 border-dashed border-outline-variant hover:border-primary-container transition-colors cursor-pointer">
                        <img class="w-full h-full object-cover"
                             data-alt="A breathtaking cinematic hero backdrop image showing a massive, glowing wormhole swirling in the deep void of space. Golden light particles and cosmic dust spiral into a dark center, casting a warm radiance against the black background. The lighting is dramatic and focused, emphasizing the scale and wonder of the celestial phenomenon. The style is hyper-realistic and high-fidelity, typical of modern sci-fi blockbusters."
                             src="https://lh3.googleusercontent.com/aida-public/AB6AXuD3oi1BrejGDWtiKb_ZJRTx1ZhgAAd1zjLjN5ZN_Lb6oDbEQMzR3aLRvYKVhNN50QqomfyZYV-W8L-HmuxdMbl4-0VOK3Ebwd9OkEdNlQ0Wonhc5OwoKxxTptfyz14yVHK1TEHsBZ6O1097Wg8VFSPRLZFShh34x3A2dmFKJUch5U5P2CoKx37f2KcBaTkw7XoKk8zwmHLyZeMhPLZuGYM8hlAzF-t4Xv2y49z5lCo-nKCcgRB3LUjIw0SwlGPosCbVX_9HgfBgTd0">
                        <div
                            class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition-opacity flex flex-col items-center justify-center gap-md">
                                <span
                                    class="material-symbols-outlined text-primary-container text-4xl">cloud_upload</span>
                            <p class="font-label-md text-white">Change Backdrop</p>
                        </div>
                    </div>
                    <div class="mt-lg grid grid-cols-2 gap-md">
                        <div
                            class="p-md bg-surface-container-low rounded-lg border border-outline-variant flex items-center gap-md">
                            <span class="material-symbols-outlined text-on-surface-variant">check_circle</span>
                            <div>
                                <p class="text-label-md text-on-surface">Poster Quality</p>
                                <p class="text-label-sm text-primary-container">Excellent (High Res)</p>
                            </div>
                        </div>
                        <div
                            class="p-md bg-surface-container-low rounded-lg border border-outline-variant flex items-center gap-md">
                            <span class="material-symbols-outlined text-on-surface-variant">check_circle</span>
                            <div>
                                <p class="text-label-md text-on-surface">Backdrop Quality</p>
                                <p class="text-label-sm text-primary-container">Good (4K HDR)</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </div>
    
    <div class="col-span-12 lg:col-span-4 space-y-gutter">
        
        <section class="glass-card p-xl rounded-xl border-l-4 border-l-primary-container">
            <h3 class="font-title-lg text-title-lg mb-lg flex items-center gap-base">
                <span class="material-symbols-outlined text-primary-container">visibility</span>
                Publishing Status
            </h3>
            <div class="space-y-md">
                <div class="flex flex-col gap-xs">
                    <label class="text-label-md text-on-surface-variant px-xs">Current Visibility</label>
                    <select
                        class="bg-surface-container-low border border-outline-variant rounded-lg p-md text-body-md text-on-surface">
                        <option selected="" value="live">Live - Visible to all users</option>
                        <option value="pending">Pending Review - Hidden from users</option>
                        <option value="archived">Archived - Hidden from users</option>
                    </select>
                </div>
                <div
                    class="p-md rounded-lg bg-primary-container/10 border border-primary-container/20 flex items-start gap-md">
                    <span class="material-symbols-outlined text-primary-container">auto_awesome</span>
                    <div>
                        <p class="text-label-md text-primary-container font-bold">Featured Movie</p>
                        <p class="text-label-sm text-on-surface-variant">This movie is currently being featured on
                            the homepage carousel.</p>
                    </div>
                </div>
            </div>
        </section>
        
        <section class="glass-card p-xl rounded-xl">
            <h3 class="font-title-lg text-title-lg mb-lg flex items-center gap-base">
                <span class="material-symbols-outlined text-primary-container">settings_suggest</span>
                Technical Metadata
            </h3>
            <div class="space-y-md">
                <div class="flex flex-col gap-xs">
                    <label class="text-label-md text-on-surface-variant px-xs">Director</label>
                    <input
                        class="bg-surface-container-low border border-outline-variant rounded-lg p-md text-body-md text-on-surface"
                        type="text" value="Christopher Nolan">
                </div>
                <div class="flex flex-col gap-xs">
                    <label class="text-label-md text-on-surface-variant px-xs">Cast List (Comma separated)</label>
                    <textarea
                        class="bg-surface-container-low border border-outline-variant rounded-lg p-md text-body-md text-on-surface resize-none"
                        rows="3">Matthew McConaughey, Anne Hathaway, Jessica Chastain, Bill Irwin, Ellen Burstyn, Michael Caine</textarea>
                </div>
                <div class="flex flex-col gap-xs">
                    <label class="text-label-md text-on-surface-variant px-xs">Production Studio</label>
                    <input
                        class="bg-surface-container-low border border-outline-variant rounded-lg p-md text-body-md text-on-surface"
                        type="text" value="Syncopy, Lyinda Obst Productions">
                </div>
                <div class="flex flex-col gap-xs">
                    <label class="text-label-md text-on-surface-variant px-xs">Primary Language</label>
                    <select
                        class="bg-surface-container-low border border-outline-variant rounded-lg p-md text-body-md text-on-surface">
                        <option selected="" value="en">English</option>
                        <option value="es">Spanish</option>
                        <option value="fr">French</option>
                        <option value="de">German</option>
                        <option value="ja">Japanese</option>
                    </select>
                </div>
            </div>
        </section>
        
        <div class="grid grid-cols-2 gap-md">
            <div class="glass-card p-md rounded-xl text-center">
                <p class="text-label-sm text-on-surface-variant">Views (30d)</p>
                <p class="font-headline-md text-primary-container">1.2M</p>
            </div>
            <div class="glass-card p-md rounded-xl text-center">
                <p class="text-label-sm text-on-surface-variant">Avg Rating</p>
                <p class="font-headline-md text-primary-container">4.9/5</p>
            </div>
            <div class="glass-card p-md rounded-xl text-center col-span-2 flex items-center justify-between px-lg">
                <p class="text-label-sm text-on-surface-variant">Last Edited</p>
                <p class="text-label-md text-on-surface">Today at 10:45 AM</p>
            </div>
        </div>
    </div>
</div>

<div
    class="mt-xl pt-lg border-t border-outline-variant flex justify-between items-center text-label-sm text-on-surface-variant">
    <p>Internal Movie ID: <span class="text-on-surface">CS-MOV-2014-INT-001</span></p>
    <div class="flex gap-lg">
        <a class="hover:text-primary-container underline" href="#">View Public Page</a>
        <a class="hover:text-error underline" href="#">Delete Record</a>
    </div>
</div>

<script src="@Assets["Components/Pages/AdminEditMovie.razor.js"]"></script>