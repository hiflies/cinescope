@page "/admin/movies/{Id:int}"
@page "/admin/movies/add"
@rendermode InteractiveServer
@using CineScope.Models
@using CineScope.Services
@using Microsoft.EntityFrameworkCore
@inject MovieRepository Repository
@inject GenreRepository GenreRepository
@inject NavigationManager Navigation
@layout AdminLayout

<PageTitle>CineScope - Admin - Edit Movie</PageTitle>

<div class="flex justify-between items-end mb-xl">
    <div>
        <nav class="flex items-center gap-base text-label-sm text-on-surface-variant mb-base">
            <span>Library</span>
            <span class="material-symbols-outlined text-[14px]">chevron_right</span>
            <span class="text-primary-container">@(Id == null ? "Add Movie" : "Edit Movie")</span>
        </nav>
        <h2 class="font-headline-lg text-headline-lg text-on-surface">
            @if (Id != null)
            {
                <span>Edit: @Title (@ReleaseYear)</span>
            }
            else
            {
                <span>Add Movie</span>
            }
        </h2>
    </div>
    <div class="flex items-center gap-md">
        <NavLink href="/admin/movies"
            class="px-xl py-md rounded-lg border border-outline-variant text-on-surface font-label-md hover:bg-surface-container-low transition-colors">
            Discard Changes
        </NavLink>
        <button
            @onclick="OnSave"
            type="button"
            class="px-xl py-md rounded-lg bg-secondary-container text-on-secondary-container font-label-md hover:brightness-110 active:scale-95 transition-all flex items-center gap-base">
            <span class="material-symbols-outlined">save</span>
            Save Changes
        </button>
    </div>
</div>

<div class="grid grid-cols-12 gap-gutter">

    <div class="col-span-12 lg:col-span-8 space-y-gutter">

        <section class="glass-card p-xl rounded-xl">
            <h3 class="font-title-lg text-title-lg mb-lg flex items-center gap-base">
                <span class="material-symbols-outlined text-primary-container">info</span>
                Primary Movie Details
            </h3>
            <div class="grid grid-cols-2 gap-md">
                <div class="col-span-2 md:col-span-1 flex flex-col gap-xs">
                    <label class="text-label-md text-on-surface-variant px-xs">Movie Title</label>
                    <input
                        @bind="Title"
                        class="bg-surface-container-low border border-outline-variant rounded-lg p-md text-body-md text-on-surface"
                        type="text">
                </div>
                <div class="col-span-2 md:col-span-1 flex flex-col gap-xs">
                    <label class="text-label-md text-on-surface-variant px-xs">Tagline</label>
                    <input
                        @bind="Tagline"
                        class="bg-surface-container-low border border-outline-variant rounded-lg p-md text-body-md text-on-surface italic"
                        type="text">
                </div>
                <div class="col-span-2 md:col-span-1 flex flex-col gap-xs">
                    <label class="text-label-md text-on-surface-variant px-xs">Release Year</label>
                    <input
                        @bind="ReleaseYear"
                        class="bg-surface-container-low border border-outline-variant rounded-lg p-md text-body-md text-on-surface"
                        type="text">
                </div>
                <div class="col-span-2 md:col-span-1 flex flex-col gap-xs">
                    <label class="text-label-md text-on-surface-variant px-xs">Duration (Minutes)</label>
                    <input
                        @bind="Duration"
                        class="bg-surface-container-low border border-outline-variant rounded-lg p-md text-body-md text-on-surface"
                        type="text">
                </div>
                <div class="col-span-2 md:col-span-1 flex flex-col gap-xs">
                    <label class="text-label-md text-on-surface-variant px-xs">Genre (Select Multiple)</label>
                    <select
                        @onchange="OnGenreChange"
                        class="bg-surface-container-low border border-outline-variant rounded-lg p-md text-body-md text-on-surface"
                        multiple>
                        @if (Genres != null)
                        {
                            foreach (var genre in Genres)
                            {
                                <option
                                    selected="@SelectedGenres.Contains(genre)"
                                    value="@genre.Id">@genre.Name</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-span-2 md:col-span-1 flex flex-col gap-xs">
                    <label class="text-label-md text-on-surface-variant px-xs">Age Rating</label>
                    <select
                        @bind="AgeRating"
                        class="bg-surface-container-low border border-outline-variant rounded-lg p-md text-body-md text-on-surface">
                        <option value="NR">NR - No rating information.</option>
                        <option value="Btl">Btl - All ages.</option>
                        <option value="7">7</option>
                        <option value="11">11</option>
                        <option value="15">15</option>
                    </select>
                </div>
            </div>
        </section>

        <section class="glass-card p-xl rounded-xl">
            <h3 class="font-title-lg text-title-lg mb-lg flex items-center gap-base">
                <span class="material-symbols-outlined text-primary-container">description</span>
                Movie Synopsis
            </h3>
            <textarea
                @bind="Description"
                class="w-full bg-surface-container-low border border-outline-variant rounded-lg p-md text-body-md text-on-surface leading-relaxed resize-none"
                rows="8"></textarea>
        </section>
    </div>

    <div class="col-span-12 lg:col-span-4 space-y-gutter">
        <section class="glass-card p-xl rounded-xl">
            <h3 class="font-title-lg text-title-lg mb-lg flex items-center gap-base">
                <span class="material-symbols-outlined text-primary-container">settings_suggest</span>
                Technical Metadata
            </h3>
            <div class="space-y-md">
                <div class="flex flex-col gap-xs">
                    <label class="text-label-md text-on-surface-variant px-xs">Director</label>
                    <input
                        @bind="Director"
                        class="bg-surface-container-low border border-outline-variant rounded-lg p-md text-body-md text-on-surface"
                        type="text">
                </div>
                <div class="flex flex-col gap-xs">
                    <label class="text-label-md text-on-surface-variant px-xs">Cast List (Comma separated)</label>
                    <textarea
                        @bind="Actors"
                        class="bg-surface-container-low border border-outline-variant rounded-lg p-md text-body-md text-on-surface resize-none"
                        rows="3"></textarea>
                </div>
            </div>
        </section>
        <section class="glass-card p-xl rounded-xl">
            <h3 class="font-title-lg text-title-lg mb-lg flex items-center gap-base">
                <span class="material-symbols-outlined text-primary-container">image</span>
                Images
            </h3>
            <div class="space-y-md">
                <div class="flex flex-col gap-xs">
                    <label class="text-label-md text-on-surface-variant px-xs">Poster Url</label>
                    <input
                        @bind="PosterUrl"
                        class="bg-surface-container-low border border-outline-variant rounded-lg p-md text-body-md text-on-surface"
                        type="text">
                </div>
                <div class="flex flex-col gap-xs">
                    <label class="text-label-md text-on-surface-variant px-xs">Backdrop Image Url</label>
                    <input
                        @bind="BackdropImageUrl"
                        class="bg-surface-container-low border border-outline-variant rounded-lg p-md text-body-md text-on-surface"
                        type="text">
                </div>
            </div>
        </section>
    </div>
</div>

<div
    class="mt-xl pt-lg border-t border-outline-variant flex justify-between items-center text-label-sm text-on-surface-variant">
    <p>Internal Movie ID: <span class="text-on-surface">CS-MOV-2014-INT-001</span></p>
    <div class="flex gap-lg">
        <a class="hover:text-primary-container underline" href="#">View Public Page</a>
        <a class="hover:text-error underline" href="#">Delete Record</a>
    </div>
</div>

<script src="@Assets["Components/Pages/AdminEditMovie.razor.js"]"></script>

@code {
    [Parameter] public int? Id { get; set; }

    private string Title { get; set; }
    private string Tagline { get; set; }
    private string ReleaseYear { get; set; }
    private string Duration { get; set; }
    private string AgeRating { get; set; }
    private string Description { get; set; }
    private string Director { get; set; }
    private string Actors { get; set; }
    private string PosterUrl { get; set; }
    private string BackdropImageUrl { get; set; }
    private Genre[]? SelectedGenres { get; set; }

    private Movie? Movie { get; set; }
    private List<Genre>? Genres { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (Id != null)
        {
            Movie = await Repository.Get((int)Id);
        }

        Genres = await GenreRepository.GetAll().ToListAsync();

        if (Movie != null)
        {
            Title = Movie.Title;
            Tagline = Movie.Tagline;
            ReleaseYear = Movie.ReleaseYear.ToString();
            Duration = Movie.Duration.ToString();
            AgeRating = Movie.AgeRating;
            Description = Movie.Description;
            Director = Movie.Director;
            Actors = Movie.Actors;
            PosterUrl = Movie.PosterUrl;
            BackdropImageUrl = Movie.BackdropImageUrl;
            SelectedGenres = Movie.Genres.ToArray();
        }
    }

    private void OnGenreChange(ChangeEventArgs e)
    {
        if (e.Value is not string[] values)
        {
            return;
        }

        var ids = values.Select(int.Parse).ToList();
        SelectedGenres = Genres?.Where(genre => ids.Contains(genre.Id)).ToArray();
    }

    private void OnSave()
    {
        if (Movie == null)
        {
            Movie = new Movie();
            Repository.Add(Movie);
        }

        Movie.Title = Title;
        Movie.Tagline = Tagline;
        Movie.ReleaseYear = int.Parse(ReleaseYear);
        Movie.Duration = int.Parse(Duration);
        Movie.AgeRating = AgeRating;
        Movie.Description = Description;
        Movie.Director = Director;
        Movie.Actors = Actors;
        Movie.PosterUrl = PosterUrl;
        Movie.BackdropImageUrl = BackdropImageUrl;
        Movie.Genres = SelectedGenres!.ToList();

        Repository.Save();
        
        Navigation.NavigateTo("/admin/movies");
    }

}
