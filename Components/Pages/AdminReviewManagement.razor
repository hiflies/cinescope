@page "/admin/reviews"
@layout AdminLayout

<PageTitle>CineScope - Admin - Reviews</PageTitle>

<section class="mb-xl">
    <h2 class="font-headline-lg text-headline-lg text-on-surface">Review Moderation</h2>
    <p class="font-body-lg text-body-lg text-on-surface-variant">Monitor and manage user-generated content to maintain
        community standards.</p>
</section>
<section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-gutter mb-xl">
    <div class="glass-card p-lg rounded-xl flex flex-col">
        <div class="flex justify-between items-start mb-sm">
            <span class="material-symbols-outlined text-primary-container">pending_actions</span>
            <span class="text-label-sm text-primary-container bg-primary-container/10 px-xs rounded">+12% vs LW</span>
        </div>
        <p class="text-label-md text-on-surface-variant uppercase tracking-wider">Pending Moderation</p>
        <h3 class="font-display-lg text-[32px] font-bold text-on-surface mt-xs">128</h3>
    </div>
    <div class="glass-card p-lg rounded-xl flex flex-col">
        <div class="flex justify-between items-start mb-sm">
            <span class="material-symbols-outlined text-secondary">smart_toy</span>
            <span class="text-label-sm text-secondary bg-secondary/10 px-xs rounded">High Priority</span>
        </div>
        <p class="text-label-md text-on-surface-variant uppercase tracking-wider">Flagged for AI Review</p>
        <h3 class="font-display-lg text-[32px] font-bold text-on-surface mt-xs">42</h3>
    </div>
    <div class="glass-card p-lg rounded-xl flex flex-col">
        <div class="flex justify-between items-start mb-sm">
            <span class="material-symbols-outlined text-tertiary">sentiment_satisfied</span>
            <span class="text-label-sm text-tertiary bg-tertiary/10 px-xs rounded">Stable</span>
        </div>
        <p class="text-label-md text-on-surface-variant uppercase tracking-wider">Avg. Sentiment Score</p>
        <h3 class="font-display-lg text-[32px] font-bold text-on-surface mt-xs">7.8<span
                class="text-title-lg text-on-surface-variant">/10</span></h3>
    </div>
    <div class="glass-card p-lg rounded-xl flex flex-col">
        <div class="flex justify-between items-start mb-sm">
            <span class="material-symbols-outlined text-on-surface">history_edu</span>
            <span class="text-label-sm text-on-surface-variant bg-surface-variant px-xs rounded">Live</span>
        </div>
        <p class="text-label-md text-on-surface-variant uppercase tracking-wider">Moderator Actions (Today)</p>
        <h3 class="font-display-lg text-[32px] font-bold text-on-surface mt-xs">312</h3>
    </div>
</section>
<section class="glass-card p-md rounded-xl mb-lg flex flex-wrap items-center gap-md">
    <div class="flex-1 min-w-[300px] relative">
        <span
            class="material-symbols-outlined absolute left-sm top-1/2 -translate-y-1/2 text-on-surface-variant">search</span>
        <input
            class="w-full bg-surface-container-lowest border border-outline-variant rounded-lg py-sm pl-xl pr-md text-body-md focus:border-primary-container outline-none transition-colors"
            placeholder="Search by reviewer or movie title..." type="text">
    </div>
    <div class="flex gap-sm">
        <select
            class="bg-surface-container-lowest border border-outline-variant text-on-surface rounded-lg px-sm py-sm focus:border-primary-container outline-none appearance-none cursor-pointer">
            <option>All Statuses</option>
            <option>Pending</option>
            <option>Approved</option>
            <option>Flagged</option>
            <option>Removed</option>
        </select>
        <select
            class="bg-surface-container-lowest border border-outline-variant text-on-surface rounded-lg px-sm py-sm focus:border-primary-container outline-none appearance-none cursor-pointer">
            <option>Sentiment</option>
            <option>Positive</option>
            <option>Neutral</option>
            <option>Negative</option>
        </select>
        <select
            class="bg-surface-container-lowest border border-outline-variant text-on-surface rounded-lg px-sm py-sm focus:border-primary-container outline-none appearance-none cursor-pointer">
            <option>Priority</option>
            <option>Urgent</option>
            <option>High</option>
            <option>Medium</option>
            <option>Low</option>
        </select>
    </div>
    <button
        class="bg-surface-container-highest text-on-surface px-md py-sm rounded-lg flex items-center gap-xs hover:bg-outline-variant transition-colors">
        <span class="material-symbols-outlined">filter_list</span>
        More Filters
    </button>
</section>
